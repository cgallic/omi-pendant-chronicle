<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- BLE: Android 12+ split permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Foreground service for BLE long-running work (Android 14+ requires explicit type) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Context block: GPS, step counter, foreground-app sampling for memory enrichment -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <!-- PACKAGE_USAGE_STATS is a special appops perm — declared here, granted via Settings → Usage access -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Wake lock to keep CPU alive during BLE notifications when screen is off -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Battery optimization exemption (one-time runtime prompt) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Android 13+: must be declared to show the FGS notification AND
         to prompt the user (otherwise requestPermissions silently denies). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Network to forward frames to agent:8772 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Health Connect: read-only access to biometric signals for memory context block -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />

    <!-- Allow query of Health Connect package presence (Android 11+ package visibility) -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <!-- BLE central role required, not optional -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:label="@string/app_name"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Pendant">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <activity
            android:name=".DebugActivity"
            android:exported="true"
            android:label="@string/debug_short_label">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.PendantForegroundService"
            android:foregroundServiceType="connectedDevice|location|mediaPlayback"
            android:exported="true" />

        <!-- Health Connect 30-day backfill: fired via
             `adb shell am broadcast -a com.connor.pendant.RUN_HEALTH_BACKFILL
                 -n com.connor.pendant/.health.BackfillReceiver`
             Result lands in logcat under tag "HealthConnectBackfill". -->
        <receiver
            android:name=".health.BackfillReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.connor.pendant.RUN_HEALTH_BACKFILL" />
            </intent-filter>
        </receiver>

        <!-- Health Connect requires a rationale screen reachable from system Settings.
             Points the privacy policy intent back at MainActivity, which renders the
             rationale in HealthConnectReader. -->
        <activity-alias
            android:name=".ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

    </application>
</manifest>
